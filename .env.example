TENSORIX_API_KEY=your-tensorix-api-key
BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NOTIFICATIONS_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_REWRITE_MODEL=deepseek/deepseek-chat-v3.1
RAG_ANSWER_MODEL=deepseek/deepseek-chat-v3.1
RAG_TOP_K_DEFAULT=8
RAG_RERANK_TOP_K_DEFAULT=4
RAG_MIN_SCORE_THRESHOLD=0.2
RAG_MAX_CONTEXT_CHARS=12000
RAG_SNIPPET_CHARS=300
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
