# StudyPilot local development defaults.
# Copy to .env and replace secrets before using non-local services.

APP_ENV=development
TESTING=false
APP_VERSION=0.1.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/learning_os
SECRET_KEY=dev-secret-key-change-me
MINI_APP_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173"]
INTERNAL_JOBS_SECRET=dev-internal-jobs-secret

BOT_TOKEN=123456:TEST_TOKEN
TELEGRAM_BOT_TOKEN=123456:TEST_TOKEN

OPENAI_API_KEY=
TENSORIX_API_KEY=
TENSORIX_BASE_URL=https://api.tensorix.ai/v1
TENSORIX_MODEL=deepseek/deepseek-chat-v3.1
LLM_PROVIDER=tensorix
EMBEDDING_PROVIDER=openai

NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_POLL_INTERVAL_SECONDS=30
WEEKLY_DIGEST_ENABLED=false
WEEKLY_DIGEST_DAY=6
WEEKLY_DIGEST_HOUR=18
WEEKLY_DIGEST_POLL_INTERVAL_SECONDS=900
WEEKLY_DIGEST_BATCH_LIMIT=100

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
VECTOR_STORE_PROVIDER=pgvector
VECTOR_SEARCH_TOP_K_DEFAULT=8
VECTOR_SEARCH_SCORE_THRESHOLD=0.2

RAG_REWRITE_MODEL=deepseek/deepseek-chat-v3.1
RAG_ANSWER_MODEL=deepseek/deepseek-chat-v3.1
RAG_TOP_K_DEFAULT=8
RAG_RERANK_TOP_K_DEFAULT=4
RAG_MIN_SCORE_THRESHOLD=0.2
RAG_MAX_CONTEXT_CHARS=12000
RAG_SNIPPET_CHARS=300

DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
DOCUMENT_CHUNK_SIZE_CHARS=1600
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_MAX_CHUNKS=500

ANALYTICS_AI_ENABLED=false
ANALYTICS_MODEL=
WEEKLY_REVIEW_AI_ENABLED=false
WEEKLY_REVIEW_MODEL=

# Test/e2e only. Never enable these in production.
TEST_AUTH_ENABLED=false
TEST_AUTH_SECRET=studypilot-test-secret
E2E_TEST_SECRET=studypilot-e2e-secret

# Frontend build-time config.
VITE_API_BASE_URL=
