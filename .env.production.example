APP_ENV=production
TESTING=false
TEST_AUTH_ENABLED=false
APP_VERSION=0.1.0
LOG_LEVEL=INFO

APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=learning_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-please
DATABASE_URL=postgresql+asyncpg://postgres:change-me-please@postgres:5432/learning_os

SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
INTERNAL_JOBS_SECRET=replace-with-a-long-random-internal-secret
MINI_APP_URL=https://app.example.com
ALLOWED_ORIGINS=["https://app.example.com"]

BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

LLM_PROVIDER=tensorix
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
TENSORIX_API_KEY=replace-with-tensorix-api-key
TENSORIX_BASE_URL=https://api.tensorix.ai/v1
TENSORIX_MODEL=deepseek/deepseek-chat-v3.1

APP_DEBUG=false
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_POLL_INTERVAL_SECONDS=30
WEEKLY_DIGEST_ENABLED=true
WEEKLY_DIGEST_DAY=6
WEEKLY_DIGEST_HOUR=18
WEEKLY_DIGEST_POLL_INTERVAL_SECONDS=900
WEEKLY_DIGEST_BATCH_LIMIT=100

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
VECTOR_STORE_PROVIDER=pgvector
VECTOR_SEARCH_TOP_K_DEFAULT=8
VECTOR_SEARCH_SCORE_THRESHOLD=0.2

RAG_REWRITE_MODEL=deepseek/deepseek-chat-v3.1
RAG_ANSWER_MODEL=deepseek/deepseek-chat-v3.1
RAG_TOP_K_DEFAULT=8
RAG_RERANK_TOP_K_DEFAULT=4
RAG_MIN_SCORE_THRESHOLD=0.2
RAG_MAX_CONTEXT_CHARS=12000
RAG_SNIPPET_CHARS=300

DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
DOCUMENT_CHUNK_SIZE_CHARS=1600
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_MAX_CHUNKS=500

ANALYTICS_AI_ENABLED=true
ANALYTICS_MODEL=
WEEKLY_REVIEW_AI_ENABLED=true
WEEKLY_REVIEW_MODEL=

VITE_API_BASE_URL=https://api.example.com
